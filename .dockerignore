# Dependencies & build output (reinstalled / regenerated in image)
node_modules
.next
out

# Git & IDE
.git
.gitignore
.cursor
.vscode

# Env & secrets (inject at runtime via compose)
.env
.env.*
!.env.example

# Logs & misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.DS_Store
Thumbs.db

# Test & coverage
coverage
.nyc_output

# Docs / deployment notes not needed in image
*.md
*.txt

# Docker (avoid churn invalidating cache)
Dockerfile*
docker-compose*.yml
.dockerignore
